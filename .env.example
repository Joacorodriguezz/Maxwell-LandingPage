# =============================================================================
# Maxwell Landing Page — Variables de entorno
# Copiá este archivo a .env.local y completá los valores reales.
# NUNCA commitees .env.local al repositorio.
# =============================================================================

# Cuenta de Gmail que envía los emails (debe tener 2FA activado)
EMAIL_USER=contacto@maxwellsa.com.ar

# App Password de Gmail (16 caracteres, SIN espacios)
# Generalo en: Cuenta Google → Seguridad → Verificación en 2 pasos → Contraseñas de aplicación
# IMPORTANTE: Gmail NO acepta la contraseña normal. Solo App Password.
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Remitente que aparece en el email (mismo que EMAIL_USER con Gmail)
EMAIL_FROM=contacto@maxwellsa.com.ar

# Destinatario interno que recibe los mensajes del formulario
CONTACT_TO=contacto@maxwellsa.com.ar

# =============================================================================
# CORS — Dominio permitido para las peticiones al backend
# =============================================================================
ALLOWED_ORIGIN=https://www.maxwellsa.com.ar

# =============================================================================
# Upstash Redis — Rate Limiting (3 requests / 15 min por IP)
# Creá una base de datos en https://console.upstash.com → Redis → Create Database
# Copiá los valores de "REST API" → URL y Token
# =============================================================================
UPSTASH_REDIS_REST_URL=https://tu-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=tu_token_aqui

# =============================================================================
# Cloudflare Turnstile — Captcha
# Creá un sitio en https://dash.cloudflare.com → Turnstile → Add site
# Site Key va en el frontend (NEXT_PUBLIC_), Secret Key solo en el backend.
# =============================================================================
NEXT_PUBLIC_TURNSTILE_SITE_KEY=tu_site_key_aqui
TURNSTILE_SECRET_KEY=tu_secret_key_aqui
